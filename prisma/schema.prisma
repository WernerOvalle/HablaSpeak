generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PREMIUM
}

enum Role {
  USER
  ADMIN
}

enum LessonLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum LessonCategory {
  GENERAL
  CALL_CENTER
  CC_INTERVIEW
}

enum PracticeSessionStatus {
  ACTIVE
  COMPLETED
}

model User {
  id             String           @id @default(cuid())
  email          String           @unique
  hashedPassword String
  name           String?
  plan           Plan             @default(FREE)
  role           Role             @default(USER)
  active         Boolean          @default(true)
  errors         ErrorRecord[]
  lessonQuestions LessonQuestion[]
  dailyAiUsages  DailyAiUsage[]
  practiceSessions InterviewPracticeSession[]
  streakCurrent  Int              @default(0)
  lastLoginAt    DateTime         @default(now())
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
}

model ErrorRecord {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  errorKey       String
  title          String
  latestFeedback String
  count          Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([userId, errorKey])
}

model Lesson {
  id          String          @id @default(cuid())
  slug        String          @unique
  title       String
  description String
  level       LessonLevel
  category    LessonCategory
  order       Int
  isPremium   Boolean         @default(false)
  syllabus    Json
  questions   LessonQuestion[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

model LessonQuestion {
  id         String   @id @default(cuid())
  lessonId   String
  userId     String
  prompt     String
  answer     String?
  feedback   String?
  lesson     Lesson   @relation(fields: [lessonId], references: [id])
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())

  @@index([lessonId, userId, createdAt])
}

model DailyAiUsage {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  dayKey    String
  count     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, dayKey])
  @@index([dayKey])
}

model InterviewPracticeSession {
  id              String                @id @default(cuid())
  userId          String
  user            User                  @relation(fields: [userId], references: [id])
  scenarioId      String
  status          PracticeSessionStatus @default(ACTIVE)
  aiResponsesCount Int                  @default(0)
  errorTally      Json
  latestCorrections Json
  finalFeedback   String?
  completedAt     DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([userId, scenarioId, status])
  @@index([userId, status, updatedAt])
}
