# Copia este archivo como .env y llena tus propios valores

# PostgreSQL / Prisma
# Docker: usar "db" como host dentro de docker-compose
DATABASE_URL=postgresql://habla:speakpass@db:5432/hablaspeak?schema=public
# Local (fuera de Docker):
# DATABASE_URL=postgresql://habla:speakpass@localhost:5432/hablaspeak?schema=public

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=cualquier-string-largo-y-aleatorio

# Groq (obtén tu key gratis en console.groq.com)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-8b-instant
# Limite diario de respuestas IA por usuario (default 30, subir a 50 al escalar)
DAILY_AI_LIMIT=30
# Numero de turnos por bloque de practica antes de mostrar feedback (default 4)
INTERVIEW_BLOCK_SIZE=8
GROQ_STT_MODEL=whisper-large-v3-turbo

# Seeds de prueba (valores por defecto si no se definen)
SEED_PREMIUM_EMAIL=premium@hablaspeak.com
SEED_PREMIUM_PASSWORD=Premium123!
SEED_FREE_EMAIL=demo@hablaspeak.com
SEED_FREE_PASSWORD=Demo123!
