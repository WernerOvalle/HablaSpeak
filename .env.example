# Copia este archivo como .env y llena tus propios valores.
# No subas tus claves reales.

# PostgreSQL / Prisma
# Docker-first (recomendado): usar host "db" dentro de docker compose
DATABASE_URL=postgresql://habla:speakpass@db:5432/hablaspeak?schema=public
# Si corres fuera de Docker, usa localhost:
# DATABASE_URL=postgresql://habla:speakpass@localhost:5432/hablaspeak?schema=public

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace_with_a_long_random_secret

# Groq
GROQ_API_KEY=replace_with_your_groq_api_key
GROQ_MODEL=llama-3.1-8b-instant
GROQ_STT_MODEL=whisper-large-v3-turbo

# Seeds de prueba
SEED_PREMIUM_EMAIL=premium@hablaspeak.com
SEED_PREMIUM_PASSWORD=Premium123!
SEED_FREE_EMAIL=demo@hablaspeak.com
SEED_FREE_PASSWORD=Demo123!