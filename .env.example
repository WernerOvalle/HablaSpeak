# .env.example
# Copia este archivo como .env.local y llena tus propios valores. ¡NO SUBAS TUS CLAVES REALES!

# OpenRouter / IA
NEXT_PUBLIC_OPENROUTER_API_KEY=your_openrouter_api_key_here

# PostgreSQL / Prisma
DATABASE_URL=postgresql://habla:speakpass@localhost:5432/hablaspeak?schema=public

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_super_secret_string_here